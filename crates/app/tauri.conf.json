{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Divi Desktop 69.01",
  "version": "69.0.2",
  "identifier": "io.diviproject.desktop69",
  "build": {
    "frontendDist": "../../ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Divi Desktop 69.01",
        "width": 1408,
        "height": 900,
        "minWidth": 1120,
        "minHeight": 720,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}